{
  "_version": "1.73.1",
  "sap.cloud": {
    "public": true,
    "service": "salesordercapture"
  },
  "sap.app": {
    "id": "salesorders",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.38"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.23.0",
      "toolsId": "2a5c7c84-2003-4265-a548-703da3c72ea8"
    },
    "dataSources": {
      "mainService": {
        "uri": "odata/v4/sales-order-capture/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "SalesOrderCapture-display": {
          "semanticObject": "SalesOrderCapture",
          "action": "display",
          "title": "{{appTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          },
          "resolutionResult": {
            "applicationType": "SAPUI5",
            "additionalInformation": "SAPUI5.Component=salesorders",
            "url": "."
          },
          "indicatorDataSource": {
            "dataSource": "mainService",
            "path": "getSalesOrderKPIs()",
            "refresh": 300
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.7",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "salesorders.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "SalesOrderRequestsList",
          "target": "SalesOrderRequestsList"
        },
        {
          "pattern": "SalesOrderRequests({key}):?query:",
          "name": "SalesOrderRequestsObjectPage",
          "target": "SalesOrderRequestsObjectPage"
        }
      ],
      "targets": {
        "SalesOrderRequestsList": {
          "type": "Component",
          "id": "SalesOrderRequestsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/SalesOrderRequests",
              "initialLoad": "Enabled",
              "variantManagement": "Page",
              "controllerExtensions": {
                "sap.fe.templates.ListReport": "salesorders.ext.controller.ListReportExtension"
              },
              "keyPerformanceIndicators": {
                "kpiToProcess": {
                  "template": "salesorders.ext.fragment.SalesOrderKPI"
                }
              },
              "navigation": {
                "SalesOrderRequests": {
                  "detail": {
                    "route": "SalesOrderRequestsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "actions": {
                    "newUpload": {
                      "press": "salesorders.ext.controller.UploadHandler.onOpenUploadDialog",
                      "text": "{{btnCreer}}",
                      "type": "Emphasized",
                      "enabled": true,
                      "visible": true,
                      "requiresSelection": false
                    }
                  },
                  "columns": {
                    "ProcessingFlow": {
                      "header": "Processing Flow",
                      "width": "10rem",
                      "horizontalAlign": "Center",
                      "availability": "Default",
                      "position": {
                        "anchor": "DataField::fileName",
                        "placement": "After"
                      },
                      "template": "salesorders.ext.fragment.ProcessingFlow"
                    }
                  }
                }
              }
            }
          }
        },
        "SalesOrderRequestsObjectPage": {
          "type": "Component",
          "id": "SalesOrderRequestsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/SalesOrderRequests"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}

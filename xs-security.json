{
  "xsappname": "sales-order-capture",
  "tenant-mode": "dedicated",
  "description": "Security configuration for sales-order-capture",
  "scopes": [
    {
      "name": "$XSAPPNAME.User",
      "description": "Use the application"
    },
    {
      "name": "uaa.user",
      "description": "UAA Token Exchange"
    }
  ],
  "role-templates": [
    {
      "name": "User",
      "description": "User role for sales-order-capture",
      "scope-references": [
        "$XSAPPNAME.User"
      ]
    },
    {
      "name": "Token_Exchange",
      "description": "UAA Token Exchange",
      "scope-references": [
        "uaa.user"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "SalesOrderCapture_User",
      "description": "Sales Order Capture User",
      "role-template-references": [
        "$XSAPPNAME.User",
        "$XSAPPNAME.Token_Exchange"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.eu10.hana.ondemand.com/**",
      "https://*.cfapps.eu10-004.hana.ondemand.com/**"
    ]
  }
}
